<UserControl x:Class="OpenRPA.Views.WorkItemQueuesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpenRPA.Views"
             xmlns:projectbase="clr-namespace:OpenRPA"
             xmlns:i="clr-namespace:OpenRPA.Interfaces;assembly=OpenRPA.Interfaces"
             xmlns:or="clr-namespace:OpenRPA.Resources"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d"  Loaded="UserControl_Loaded"
             d:DesignHeight="500" d:DesignWidth="900">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <i:ComboBoxEmptyItemConverter x:Key="ComboBoxEmptyItemConverter" />
            <projectbase:DebugDataBindingConverter x:Key="DebugBinding" />
        </ResourceDictionary>
    </UserControl.Resources>

    <DockPanel Background="White">
        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E2E6EB" 
                BorderThickness="0,0,0,1" Padding="8,6">
            <StackPanel Orientation="Horizontal">
                <Button Content="{x:Static or:strings.addnewworkitemqueue}" 
                        Click="Button_CreateWorkItemQueue"
                        MinWidth="50" Margin="0,0,7,0" Padding="5,0" />
                <Button Content="{x:Static or:strings.main_reload}" 
                        Click="Button_Refresh_Click"
                        MinWidth="50" Margin="0,0,7,0" Padding="5,0" />
                <Button Content="{x:Static or:strings.delete}" 
                        Click="Button_DeleteQueue_Click"
                        MinWidth="50" Padding="5,0" />
            </StackPanel>
        </Border>

        <Grid Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="160" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left Panel: Queue List -->
            <ListBox Grid.Column="0" 
                     x:Name="listWorkItemQueues" 
                     ItemsSource="{Binding WorkItemQueues}" 
                     SelectionMode="Extended"
                     Background="White" 
                     BorderThickness="0"
                     Padding="0,4"
                     SelectionChanged="listWorkItemQueues_SelectionChanged"
                     KeyUp="listWorkItemQueues_KeyUp">
                <ListBox.ItemTemplate>
                    <HierarchicalDataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="8,4">
                            <Image Source="/OpenRPA;component/Resources/state/workitemqueue.png" 
                                   Width="16" Height="16" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding Path=name}" />
                        </StackPanel>
                    </HierarchicalDataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Separator -->
            <GridSplitter Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Stretch" 
                          ResizeDirection="Columns" Width="2" Background="#E2E6EB" />

            <!-- Right Panel -->
            <Grid Grid.Column="2" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Details Panel -->
                <Grid Grid.Row="0" x:Name="pnlDetails" Visibility="Collapsed" Margin="12,8,12,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Basic Config -->
                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{x:Static or:strings.wiq_configuration}" 
                                   FontWeight="Bold" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6">
                                <TextBlock Text="{x:Static or:strings.project}" Margin="0,0,0,2" />
                                <ComboBox x:Name="listProjects" 
                                          ItemsSource="{Binding Projects, Converter={StaticResource ComboBoxEmptyItemConverter}}" 
                                          SelectedValuePath="_id" 
                                          SelectedValue="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.projectid}"
                                          DisplayMemberPath="name"
                                          SelectionChanged="listProjects_SelectionChanged" />
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,6">
                                <TextBlock Text="{x:Static or:strings.robotorrole}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{Binding Robots, Converter={StaticResource ComboBoxEmptyItemConverter}}" 
                                          SelectedValuePath="_id" 
                                          SelectedValue="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.robotqueue}"
                                          DisplayMemberPath="name" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,6">
                                <TextBlock Text="{x:Static or:strings.workflow}" Margin="0,0,0,2" />
                                <ComboBox x:Name="listWorkflows" 
                                          ItemsSource="{Binding Workflows, Converter={StaticResource ComboBoxEmptyItemConverter}}" 
                                          SelectedValuePath="ProjectAndName" 
                                          DisplayMemberPath="ProjectAndName"
                                          SelectedValue="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.workflowid}" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,6">
                                <TextBlock Text="{x:Static or:strings.wiq_amqp}" Margin="0,0,0,2" />
                                <TextBox Text="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.amqpqueue, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Queue Parameters -->
                    <StackPanel Grid.Row="1" Margin="0,8,0,0">
                        <TextBlock Text="{x:Static or:strings.wiq_parameters}" 
                                   FontWeight="Bold" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{x:Static or:strings.wiq_maxretries}" Margin="0,0,0,2" />
                                <hc:NumericUpDown Value="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.maxretries, UpdateSourceTrigger=PropertyChanged}" 
                                                 Minimum="0" Maximum="100" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                <TextBlock Text="{x:Static or:strings.wiq_retrydelay}" Margin="0,0,0,2" />
                                <hc:NumericUpDown Value="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.retrydelay, UpdateSourceTrigger=PropertyChanged}" 
                                                 Minimum="0" Maximum="3600" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                <TextBlock Text="{x:Static or:strings.wiq_initialdelay}" Margin="0,0,0,2" />
                                <hc:NumericUpDown Value="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.initialdelay, UpdateSourceTrigger=PropertyChanged}" 
                                                 Minimum="0" Maximum="3600" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Success / Failed + Purge -->
                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <TextBlock Text="{x:Static or:strings.wiq_success_failed}" 
                                   FontWeight="Bold" Margin="0,0,0,6" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="{x:Static or:strings.activity_addworkitem_success_wiq}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{Binding WorkItemQueues, Converter={StaticResource ComboBoxEmptyItemConverter}}" 
                                          SelectedValuePath="name" 
                                          SelectedValue="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.success_wiq}"
                                          DisplayMemberPath="name" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="{x:Static or:strings.activity_addworkitem_failed_wiq}" Margin="0,0,0,2" />
                                <ComboBox ItemsSource="{Binding WorkItemQueues, Converter={StaticResource ComboBoxEmptyItemConverter}}" 
                                          SelectedValuePath="name" 
                                          SelectedValue="{Binding ElementName=listWorkItemQueues, Path=SelectedValue.failed_wiq}"
                                          DisplayMemberPath="name" />
                            </StackPanel>
                        </Grid>
                        <Button Content="{x:Static or:strings.wiq_purge}" 
                                Click="PurgeButton_Click"
                                MinWidth="50" Padding="5,0" 
                                HorizontalAlignment="Left" Margin="0,8,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Section separator -->
                <Border Grid.Row="1" x:Name="sectionSplitter" Visibility="Collapsed"
                        Height="1" Background="#E2E6EB" Margin="12,8,12,4" />

                <!-- Empty State -->
                <TextBlock Grid.Row="2" x:Name="pnlEmpty"
                           Text="{x:Static or:strings.wiq_empty_hint}" 
                           FontSize="14" Foreground="#999" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                <!-- WorkItems Panel -->
                <Grid Grid.Row="2" x:Name="workItemsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,4,12,4">
                        <TextBlock Text="{x:Static or:strings.wiq_workitems}" FontWeight="Bold" />
                        <TextBlock Text=" (" />
                        <TextBlock x:Name="lblWorkItemCount" Text="0" />
                        <TextBlock Text=")" />
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              x:Name="listWorkItems" 
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="12,0,12,8"
                              ItemsSource="{Binding WorkItems, UpdateSourceTrigger=PropertyChanged}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static or:strings.name}" Binding="{Binding name}" Width="2*" />
                            <DataGridTextColumn Header="{x:Static or:strings.state}" Binding="{Binding state}" Width="*" />
                            <DataGridTextColumn Header="{x:Static or:strings.wiq_priority}" Binding="{Binding priority}" Width="*" />
                            <DataGridTextColumn Header="{x:Static or:strings.wiq_retries}" Binding="{Binding retries}" Width="*" />
                            <DataGridTextColumn Header="{x:Static or:strings.open_modified}" Binding="{Binding _modified}" Width="1.5*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
