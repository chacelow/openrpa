<Window x:Class="OpenRPA.Views.WorkitemQueue"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenRPA.Views"
        xmlns:or="clr-namespace:OpenRPA.Resources"
        mc:Ignorable="d"
        FocusManager.FocusedElement="{Binding ElementName=txtName}"
        Title="{x:Static or:strings.addnewworkitemqueue}" 
        Height="180" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <!-- Custom window chrome -->
    <Border Background="White" CornerRadius="8" BorderBrush="#E2E6EB" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" BlurRadius="15" Opacity="0.15" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="#FAFBFC" CornerRadius="8,8,0,0" Padding="16,10" 
                    BorderBrush="#E2E6EB" BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <TextBlock Text="{x:Static or:strings.addnewworkitemqueue}" 
                               FontWeight="Bold" FontSize="14" Foreground="#333" 
                               VerticalAlignment="Center" />
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center" 
                            Width="28" Height="28" FontSize="12"
                            Background="Transparent" BorderThickness="0" Foreground="#999"
                            Click="CancelButton_Click"
                            Cursor="Hand" />
                </Grid>
            </Border>

            <!-- Content -->
            <StackPanel Grid.Row="1" Margin="20,16">
                <TextBlock Text="{x:Static or:strings.name}" FontWeight="SemiBold" 
                           Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" 
                         Text="{Binding item.name, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" 
                         KeyUp="txtName_KeyUp"
                         MinHeight="32"
                         Padding="8,6"
                         FontSize="13"
                         BorderBrush="#D0D5DD" BorderThickness="1"
                         VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" 
                        Margin="0,0,20,16">
                <Button Content="{x:Static or:strings.button_cancel}" 
                        Click="CancelButton_Click" 
                        MinWidth="80" Padding="10,6" Margin="0,0,10,0"
                        Background="White" BorderBrush="#D0D5DD" BorderThickness="1" Cursor="Hand"
                        FontSize="12">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="{x:Static or:strings.button_ok}" 
                        Click="OkButton_Click" 
                        MinWidth="80" Padding="10,6"
                        Background="#1967D2" Foreground="White" BorderThickness="0" Cursor="Hand"
                        FontSize="12">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4" />
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
