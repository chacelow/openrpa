<Window x:Class="OpenRPA.Views.WelcomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Welcome to OpenRPA" Height="500" Width="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <SolidColorBrush x:Key="CardBorder" Color="#E0E0E0" />
        <SolidColorBrush x:Key="CardSelected" Color="#E3F2FD" />
        <SolidColorBrush x:Key="CardSelectedBorder" Color="#1E88E5" />
        <Style x:Key="OptionCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="10" />
        </Style>
    </Window.Resources>
    <Border Background="#F5F5F5" CornerRadius="16" BorderBrush="#D0D0D0" BorderThickness="1">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="40,30,40,10">
                <TextBlock Text="Welcome to OpenRPA" FontSize="28" FontWeight="Bold" 
                           Foreground="#212121" HorizontalAlignment="Center" />
                <TextBlock Text="Choose how you want to get started" FontSize="15" 
                           Foreground="#757575" HorizontalAlignment="Center" Margin="0,8,0,0" />
                <TextBlock Text="You can change this anytime in Settings" FontSize="12" 
                           Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Cards -->
            <Grid Grid.Row="1" Margin="40,10,40,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Cloud Option -->
                <Border Grid.Column="0" Style="{StaticResource OptionCard}"
                        MouseLeftButtonDown="CloudCard_Click" x:Name="CloudCard">
                    <StackPanel>
                        <!-- Icon -->
                        <TextBlock Text="☁️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15" />
                        <TextBlock Text="Cloud (OpenFlow)" FontSize="20" FontWeight="Bold" 
                                   Foreground="#1E88E5" HorizontalAlignment="Center" />
                        <TextBlock Text="Connect to OpenFlow cloud" FontSize="13" 
                                   Foreground="#757575" HorizontalAlignment="Center" Margin="0,5,0,0" />
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#9E9E9E" 
                                   Margin="0,15,0,0" LineHeight="18">
                            <Run Text="• Sync workflows across machines&#x0a;" />
                            <Run Text="• Multi-robot orchestration&#x0a;" />
                            <Run Text="• Remote workflow execution&#x0a;" />
                            <Run Text="• WorkItem queuing system&#x0a;" />
                            <Run Text="• User &amp; role management&#x0a;" />
                            <Run Text="• Version control &amp; collaboration" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Local Option -->
                <Border Grid.Column="1" Style="{StaticResource OptionCard}"
                        MouseLeftButtonDown="LocalCard_Click" x:Name="LocalCard">
                    <StackPanel>
                        <!-- Icon -->
                        <TextBlock Text="💻" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15" />
                        <TextBlock Text="Local Only" FontSize="20" FontWeight="Bold" 
                                   Foreground="#43A047" HorizontalAlignment="Center" />
                        <TextBlock Text="Work completely offline" FontSize="13" 
                                   Foreground="#757575" HorizontalAlignment="Center" Margin="0,5,0,0" />
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#9E9E9E" 
                                   Margin="0,15,0,0" LineHeight="18">
                            <Run Text="• No login required&#x0a;" />
                            <Run Text="• Design &amp; record workflows&#x0a;" />
                            <Run Text="• UI automation (UIA/MSAA)&#x0a;" />
                            <Run Text="• Image recognition + OCR&#x0a;" />
                            <Run Text="• SAP / Browser / Office automation&#x0a;" />
                            <Run Text="• Everything stored locally" />
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom: Cloud URL (shown when cloud selected) + Get Started -->
            <StackPanel Grid.Row="2" Margin="40,0,40,30">
                <!-- OpenFlow URL input -->
                <StackPanel x:Name="UrlPanel" Visibility="Collapsed" Margin="0,0,0,12">
                    <TextBlock Text="OpenFlow Server URL:" FontSize="13" Foreground="#616161" Margin="0,0,0,5" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtWsUrl" Text="wss://app.openiap.io/" 
                                 FontSize="13" Padding="10,8" 
                                 BorderBrush="#BDBDBD" BorderThickness="1"
                                 Background="White" />
                    </Grid>
                </StackPanel>
                <Button x:Name="btnStart" Content="Get Started →" 
                        FontSize="16" FontWeight="Bold"
                        Background="#1E88E5" Foreground="White"
                        BorderThickness="0" Padding="40,12"
                        Cursor="Hand"
                        Click="BtnStart_Click"
                        HorizontalAlignment="Center" MinWidth="200">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="8" 
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Tip: press ESC to choose local mode by default" 
                           FontSize="11" Foreground="#BDBDBD" HorizontalAlignment="Center" Margin="0,8,0,0" />
            </StackPanel>
        </Grid>
    </Border>

</Window>
