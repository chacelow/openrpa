<UserControl x:Class="OpenRPA.Views.OpenProject"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:OpenRPA.Views"
             xmlns:localroot="clr-namespace:OpenRPA"
             xmlns:or="clr-namespace:OpenRPA.Resources"
             xmlns:projectbase="clr-namespace:OpenRPA"
             d:DataContext="{d:DesignInstance Type=local:OpenProject}"
             mc:Ignorable="d" KeyUp="UserControl_KeyUp"
             d:DesignHeight="450" d:DesignWidth="800">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <localroot:BindingProxy x:Key="proxy" Data="{Binding}" />
            <local:SimpleBindingConverter x:Key="bindingConverter" />
            <local:SortConverter x:Key="sortConverter" />

            <HierarchicalDataTemplate DataType="{x:Type projectbase:Project}" ItemsSource="{Binding Path=Children}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding name}"/>
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static or:strings.export}" Command="{Binding Data.ExportCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.delete}" Command="{Binding Data.DeleteCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.addnewworkitemqueue}" Command="{Binding Data.AddWorkItemQueueCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                </StackPanel>
            </HierarchicalDataTemplate>

            <HierarchicalDataTemplate DataType="{x:Type projectbase:Workflow}" ItemsSource="{Binding Workflows}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="{Binding StateImage}" Width="16" Height="16" />
                    <TextBlock Text="{Binding name}" />
                    <StackPanel.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{x:Static or:strings.play}" Command="{Binding Data.PlayCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.rename}" Command="{Binding Data.RenameCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.export}" Command="{Binding Data.ExportCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.copyid}" Command="{Binding Data.CopyIDCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.copyrelativefilename}" Command="{Binding Data.CopyRelativeFilenameCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.delete}" Command="{Binding Data.DeleteCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.menu_get_server_version}" Command="{Binding Data.GetServerVersionCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                            <MenuItem Header="{x:Static or:strings.copy}" Command="{Binding Data.CopyCommand, Source={StaticResource proxy}}" CommandParameter="{Binding}" />
                        </ContextMenu>
                    </StackPanel.ContextMenu>
                </StackPanel>
            </HierarchicalDataTemplate>

            <HierarchicalDataTemplate DataType="{x:Type projectbase:Detector}" ItemsSource="{Binding Detectors}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/OpenRPA;component/Resources/state/sensor.png" Width="16" Height="16" />
                    <TextBlock Text="{Binding name}"/>
                </StackPanel>
            </HierarchicalDataTemplate>

            <HierarchicalDataTemplate DataType="{x:Type projectbase:WorkitemQueue}" ItemsSource="{Binding WorkItemQueues}">
                <StackPanel Orientation="Horizontal">
                    <Image Source="/OpenRPA;component/Resources/state/workitemqueue.png" Width="16" Height="16" />
                    <TextBlock Text="{Binding name}"/>
                </StackPanel>
            </HierarchicalDataTemplate>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TreeView x:Name="listWorkflows" ItemsSource="{Binding Projects}"
                  Grid.Column="0" Background="White" BorderThickness="0" Padding="4,0,8,0"
                  MouseDoubleClick="ListWorkflows_MouseDoubleClick"
                  SelectedItemChanged="listWorkflows_SelectedItemChanged"
                  DragDrop.Drop="listWorkflows_Drop"
                  PreviewMouseLeftButtonDown="listWorkflows_PreviewMouseLeftButtonDown"
                  PreviewMouseMove="listWorkflows_PreviewMouseMove"
                  AllowDrop="True">
            <TreeView.ItemContainerStyle>
                <Style TargetType="{x:Type TreeViewItem}">
                    <Setter Property="Visibility" Value="Visible" />
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    <Setter Property="FontWeight" Value="Normal" />
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="FontWeight" Value="Bold" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <Border Grid.Column="1" Width="1" Background="#E2E6EB" />

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Padding="12,0,12,0">
            <StackPanel Background="White">
                <TextBlock Text="{x:Static or:strings.open_edit}" FontWeight="Bold" Margin="0,4,0,2"/>
                <CheckBox IsChecked="{Binding ElementName=listWorkflows, Path=SelectedValue.disable_local_caching}" Content="{x:Static or:strings.disable_local_caching}" Command="{Binding Data.DisableCachingCommand, Source={StaticResource proxy}}" Margin="8,2,0,0"/>
                <CheckBox IsChecked="{Binding ElementName=listWorkflows, Path=SelectedValue.Serializable}" Content="{x:Static or:strings.disable_serializable}" Command="{Binding Data.SerializableCommand, Source={StaticResource proxy}}" Margin="8,2,0,0"/>
                <CheckBox IsChecked="{Binding ElementName=listWorkflows, Path=SelectedValue.background}" Content="{x:Static or:strings.openproject_background}" Command="{Binding Data.BackgroundCommand, Source={StaticResource proxy}}" Margin="8,2,0,0"/>
                <CheckBox IsChecked="{Binding ElementName=listWorkflows, Path=SelectedValue.save_output}" Content="{x:Static or:strings.openproject_save_output}" Command="{Binding Data.SaveOutputCommand, Source={StaticResource proxy}}" Margin="8,2,0,0"/>
                <CheckBox IsChecked="{Binding ElementName=listWorkflows, Path=SelectedValue.send_output}" Content="{x:Static or:strings.openproject_send_output}" Command="{Binding Data.SendOutputCommand, Source={StaticResource proxy}}" Margin="8,2,0,0"/>

                <StackPanel x:Name="EditXAMLPanel">
                    <TextBlock Text="{x:Static or:strings.open_edit}" FontWeight="Bold" Margin="0,8,0,2"/>
                    <Button Click="ButtonEditXAML" Content="{x:Static or:strings.open_edit_xaml}" IsEnabled="{Binding IsWorkflowSelected,Mode=OneWay}" Margin="8,2,0,0" Padding="8,4" HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel x:Name="PackageManagerPanel">
                    <TextBlock Text="{x:Static or:strings.open_package_manager}" FontWeight="Bold" Margin="0,8,0,2"/>
                    <Button Click="ButtonOpenPackageManager" Content="{x:Static or:strings.open_package_manager}" IsEnabled="{Binding IsWorkflowOrProjectSelected,Mode=OneWay}" Margin="8,2,0,0" Padding="8,4" HorizontalAlignment="Left"/>
                </StackPanel>

                <TextBlock Text="{x:Static or:strings.open_name}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue.name}"/>
                <TextBlock Text="{x:Static or:strings.open_filename}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue.Filename}"/>
                <TextBlock Text="Id" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue._id}"/>
                <TextBlock Text="{x:Static or:strings.open_culture}" FontWeight="Bold" Margin="0,8,0,2"/>
                <ComboBox ItemsSource="{Binding Cultures}" DisplayMemberPath="NativeName" SelectedValuePath="Name"
                          SelectedValue="{Binding ElementName=listWorkflows, Path=SelectedValue.culture}" Margin="8,2,0,0"/>
                <TextBlock Text="{x:Static or:strings.open_state}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue.State}"/>
                <TextBlock Text="{x:Static or:strings.open_serializable}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue.Serializable}"/>
                <TextBlock Text="{x:Static or:strings.open_createdby}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue._createdby}"/>
                <TextBlock Text="{x:Static or:strings.open_created}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue._created}"/>
                <TextBlock Text="{x:Static or:strings.open_modifiedby}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue._modifiedby}"/>
                <TextBlock Text="{x:Static or:strings.open_modified}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue._modified}"/>
                <TextBlock Text="{x:Static or:strings.version}" FontWeight="Bold" Margin="0,8,0,2"/>
                <TextBlock Margin="8,2,0,0" Text="{Binding ElementName=listWorkflows, Path=SelectedValue._version}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
