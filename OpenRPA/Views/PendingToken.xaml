<Window x:Class="OpenRPA.Views.PendingToken"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OpenRPA.Views"
        xmlns:or="clr-namespace:OpenRPA.Resources"
        mc:Ignorable="d"
        Closing="Window_Closing"
        FocusManager.FocusedElement="{Binding ElementName=lnkLogin}"
        Title="Not logged in" Height="210" Width="480" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <StackPanel Margin="16">
        <TextBlock TextWrapping="Wrap" FontSize="14" FontWeight="SemiBold"
                   Text="{x:Static or:strings.pendingtokenwindows_message}"></TextBlock>
        <StackPanel Margin="0,14,0,0">
            <TextBlock TextWrapping="Wrap" Foreground="Gray" Margin="0,0,0,4"
                       Text="Click the link below to open the login page in your browser:"></TextBlock>
            <TextBlock x:Name="lnkLogin" Foreground="DodgerBlue" Cursor="Hand"
                       TextDecorations="Underline" MouseLeftButtonDown="LnkLogin_Click" Margin="0,4,0,0">
            </TextBlock>
        </StackPanel>
        <CheckBox x:Name="chkDontRemind" Content="Don't remind me again" Margin="0,10,0,0"></CheckBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="btnCancel" Click="CancelButton_Click" MinWidth="70" Height="28"
                    Padding="12,4,12,4" Content="{x:Static or:strings.button_cancel}" IsCancel="True"></Button>
        </StackPanel>
    </StackPanel>
</Window>
